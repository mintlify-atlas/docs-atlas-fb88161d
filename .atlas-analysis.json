  "keyFeatures": [
    "Responsive admin dashboard UI with light/dark mode",
    "Built-in customizable sidebar with multiple variants",
    "Advanced data tables with filtering, sorting, and pagination",
    "Global command/search menu for navigation",
    "Pre-built authentication pages (sign-in, sign-up, OTP, forgot password)",
    "RTL (Right-to-Left) language support",
    "Multiple layout options (default, compact, full)",
    "30+ customized Shadcn UI components",
    "Settings pages with profile, account, appearance, and notifications",
    "Error pages (401, 403, 404, 500, maintenance)",
    "TanStack Router integration with type-safe routing",
    "Clerk authentication integration support",
    "Chart and analytics components with Recharts",
    "Form validation with React Hook Form and Zod"
  ],
  "publicApiSurface": [
    "AppSidebar - Main sidebar component",
    "AuthenticatedLayout - Layout wrapper for authenticated pages",
    "CommandMenu - Global search/command palette",
    "ConfigDrawer - Layout and theme configuration drawer",
    "DataTable - Advanced table component with filtering and sorting",
    "DatePicker - Custom date picker component",
    "PasswordInput - Password input with visibility toggle",
    "ThemeSwitch - Theme mode switcher component",
    "useLayout - Layout configuration hook",
    "useTheme - Theme management hook",
    "sidebarData - Navigation structure configuration",
    "Main layout variants: default, compact, full",
    "Sidebar variants: sidebar, floating, inset",
    "Collapsible modes: offcanvas, icon, none",
    "Profile, Account, Appearance, Notifications, Display settings pages",
    "Dashboard with analytics and overview components",
    "Tasks management with data table",
    "Users management with CRUD operations",
    "Chats interface with messaging UI",
    "Apps integration showcase",
    "Error pages: Unauthorized, Forbidden, NotFound, InternalServerError, Maintenance"
  ]
